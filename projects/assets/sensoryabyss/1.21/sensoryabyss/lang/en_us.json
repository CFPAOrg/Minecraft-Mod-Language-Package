  "_comment_subclass_descriptions": "Subclass descriptions",
  "subclass.sensoryabyss.radiant.description": "Flashy AoE pressure. Weaponize light â€” supercharged echo pulses and nova bursts.",
  "subclass.sensoryabyss.shade.description": "Calm precision. Thrive in darkness â€” shadow dash to targets, create dark zones for stealth.",
  "subclass.sensoryabyss.frequency_rider.description": "Kinetic shooter. Echo Shots ricochet between enemies; Resonant Dash phases through fights. Combat builds Frequency stacks that scale movement, fire rate, and damage.",
  "subclass.sensoryabyss.harmonic.description": "Supportive harmony. Toggle song auras to buff allies, build Crescendo on damage taken, chain Cone-Pulse-Wave to trigger a Finale.",
  "subclass.sensoryabyss.monolith.description": "Living fortress. Absorb material and become it â€” stone armor, iron bones, lava shield.",
  "subclass.sensoryabyss.shardborn.description": "Walking weapon. Absorb material and weaponize it â€” jagged edges, piercing blows, eruptions.",
  "subclass.sensoryabyss.corpse_eater.description": "Manipulate your blood to shift between three combat stances â€” Striker, Reaver, Drinker. Read the fight, redirect your blood, execute melee.",
  "subclass.sensoryabyss.necromancer.description": "Field a hierarchy of undead. Souls fuel your raises; stances command your dead. Your army is your shield.",
  "_comment_abilities": "Abilities",
